# Copy these values into Render Environment Variables.
# Do not commit real API keys or passwords.

DATABASE_TYPE=mysql
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-mysql-database

API_KEYS=["your-gemini-api-key-1","your-gemini-api-key-2"]
ALLOWED_TOKENS=["replace-with-your-workbuddy-api-token"]
AUTH_TOKEN=replace-with-your-admin-token

BASE_URL=https://generativelanguage.googleapis.com/v1beta
SHOW_THINKING_PROCESS=true
FAKE_STREAM_ENABLED=false
TOOLS_CODE_EXECUTION_ENABLED=false
URL_CONTEXT_ENABLED=false
TZ=Asia/Shanghai
